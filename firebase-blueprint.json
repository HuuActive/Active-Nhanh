{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Digital service product offered by ActiveNhanh",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "importantNote": { "type": "string" },
        "deliveryProcess": { "type": "string" },
        "features": { "type": "string" },
        "warranty": { "type": "string" },
        "faqs": { "type": "string" },
        "usageGuide": { "type": "string" },
        "shortFeatures": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "stock": { "type": "number" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "seoKeywords": { "type": "string" }
      },
      "required": ["name", "price", "description", "category", "image"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer review for a product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userName", "rating", "comment"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerInfo": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" },
            "note": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerInfo", "items", "total", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "slug", "order"]
    },
    "Post": {
      "title": "Post",
      "description": "Technology news post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "thumbnail": { "type": "string" },
        "category": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "authorId"]
    },
    "PostComment": {
      "title": "PostComment",
      "description": "Comment on a news post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "spam"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "content", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of digital service products"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of product reviews"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of technology news posts"
    },
    "/post_comments/{commentId}": {
      "schema": "PostComment",
      "description": "Collection of post comments"
    },
    "/consultations/{consultationId}": {
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "message": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "contacted", "closed"] },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["name", "email", "status", "createdAt"]
      },
      "description": "Collection of consultation requests"
    }
  }
}
